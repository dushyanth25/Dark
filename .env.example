# ============================================================================
# Environment Variables Template - COPY TO .env AND FILL IN VALUES
# ============================================================================
# IMPORTANT: Never commit .env file with actual secrets!
# Copy this file to .env and fill in your actual values.
# .env is in gitignore and will not be committed.
# ============================================================================

# ============================================================================
# Node Environment
# ============================================================================
NODE_ENV=development

# ============================================================================
# Server Configuration
# ============================================================================
# Server port
SERVER_PORT=5000

# Server host
SERVER_HOST=localhost

# Base URL for frontend to reach backend
REACT_APP_API_BASE_URL=http://localhost:5000/api

# ============================================================================
# Database Configuration
# ============================================================================
# MongoDB connection string
# Format: mongodb://username:password@host:port/database
# For local: mongodb://localhost:27017/game_theory_db
MONGODB_URI=mongodb://localhost:27017/game_theory_db

# ============================================================================
# JWT / Authentication
# ============================================================================
# Secret key for JWT token signing (use a strong, random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT expiration time
JWT_EXPIRE=7d

# ============================================================================
# Third-Party API Keys & Services
# ============================================================================
# Groq API (for AI/LLM features)
GROQ_API_KEY=your_groq_api_key_here

# If using other AI services
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================================================
# Email Configuration (for sending emails/notifications)
# ============================================================================
# SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# SMTP Credentials
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Email sender address
EMAIL_FROM=noreply@game-theory-app.com

# ============================================================================
# Authentication Providers (if using OAuth)
# ============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ============================================================================
# Frontend Configuration
# ============================================================================
# React environment
REACT_APP_ENV=development

# API endpoints
REACT_APP_API_URL=http://localhost:5000

# Feature flags
REACT_APP_ENABLE_DEBUG=false
REACT_APP_ENABLE_ANALYTICS=false

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: error, warn, info, debug, trace
LOG_LEVEL=info

# Log file path
LOG_PATH=./logs

# ============================================================================
# Session Configuration
# ============================================================================
# Session secret for express-session
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Session directory
SESSION_STORE_PATH=./sessions

# ============================================================================
# CORS Configuration
# ============================================================================
# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# ============================================================================
# Rate Limiting
# ============================================================================
# Rate limit: requests per minute
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# ============================================================================
# File Upload Configuration
# ============================================================================
# Max file upload size (in bytes)
MAX_FILE_SIZE=5242880

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# Upload directory
UPLOAD_DIR=./uploads

# ============================================================================
# SonarQube Configuration (for CI/CD)
# ============================================================================
# SonarQube server URL
SONAR_HOST_URL=http://localhost:9000

# SonarQube project key
SONAR_PROJECT_KEY=mern-app

# SonarQube authentication token
SONAR_TOKEN=your_sonar_token_here

# ============================================================================
# Jenkins Configuration (for CI/CD)
# ============================================================================
# Jenkins server URL (for webhooks)
JENKINS_URL=http://localhost:8080

# GitHub personal access token for Jenkins
GITHUB_TOKEN=your_github_personal_access_token

# ============================================================================
# Cache Configuration (if using Redis)
# ============================================================================
# Redis connection string
REDIS_URL=redis://localhost:6379

# Redis password (if required)
REDIS_PASSWORD=

# ============================================================================
# Storage Configuration (S3, etc.)
# ============================================================================
# AWS S3 configuration (if using S3 for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_S3_REGION=us-east-1

# ============================================================================
# Feature Flags & Toggles
# ============================================================================
# Enable/disable features
FEATURE_COACHING_PANEL=true
FEATURE_VOICE_ASSISTANT=true
FEATURE_LEADERBOARD=true
FEATURE_ADMIN_PANEL=true

# ============================================================================
# Security Configuration
# ============================================================================
# Enable HTTPS
USE_HTTPS=false

# Certificate paths (if using HTTPS)
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Content Security Policy
CSP_ENABLED=true

# ============================================================================
# Backup & Recovery
# ============================================================================
# Backup directory
BACKUP_DIR=./backups

# Backup frequency (in hours)
BACKUP_FREQUENCY=24

# ============================================================================
# Development Tools
# ============================================================================
# Enable source maps in production
SOURCE_MAPS=false

# Enable hot reload
HOT_RELOAD=true

# ============================================================================
# Instructions
# ============================================================================
#
# 1. Copy this file to create .env:
#    cp .env.example .env
#
# 2. Fill in all values with your actual configuration
#
# 3. For development, you can use the default values marked with [DEV]
#
# 4. For production, CHANGE all sensitive values:
#    - JWT_SECRET
#    - SESSION_SECRET
#    - API keys
#    - Database URL
#    - Email credentials
#
# 5. Never commit .env file (it's in .gitignore)
#
# 6. Securely share .env values with your team using:
#    - Environment management tools (HashiCorp Vault, AWS Secrets Manager)
#    - Password managers
#    - Encrypted files
#
# ============================================================================
# Production Checklist
# ============================================================================
# Before deploying to production, ensure:
# ✓ All secrets are changed from defaults
# ✓ NODE_ENV is set to 'production'
# ✓ HTTPS is enabled (USE_HTTPS=true)
# ✓ JWT_SECRET and SESSION_SECRET are strong, random values
# ✓ Database URL points to production database
# ✓ API keys are valid and for production services
# ✓ Email configuration is correct
# ✓ CORS_ORIGIN is set to your production domain only
# ✓ Logging is configured (not too verbose)
# ✓ Backup configuration is correct
# ✓ CDN/caching is configured if needed
#
# ============================================================================
# EOF - .env.example
# ============================================================================
