# ============================================================================
# .gitignore for MERN Stack Project with CI/CD Pipeline
# ============================================================================
# Comprehensive gitignore to exclude build artifacts, dependencies,
# sensitive files, and CI/CD temporary files
# ============================================================================

# ============================================================================
# Node & NPM
# ============================================================================
node_modules/
npm-debug.log
npm-debug.log.*
yarn-error.log
yarn-debug.log
package-lock.json
yarn.lock
.npm
.eslintcache
.node_repl_history

# ============================================================================
# Build Artifacts & Distribution Files
# ============================================================================
dist/
build/
out/
.next/
*.tgz
*.tar.gz
*.jar
*.exe
*.app
*.dmg

# ============================================================================
# React & Frontend
# ============================================================================
client/dist/
client/build/
client/.next
client/out
client/*.tsbuildinfo
client/.env.local
client/.env.*.local

# ============================================================================
# Backend
# ============================================================================
server/dist/
server/build/
server/.env
server/.env.local
server/.env.*.local

# ============================================================================
# Environment & Secrets
# ============================================================================
.env
.env.local
.env.*.local
.env.*.example
.env.production.local
.env.test.local
.env.development.local
*.secret
*.key
.npmrc
.yarnrc
# Kubernetes secrets (NEVER commit real secrets!)
k8s/.env
k8s/.env.*

# ============================================================================
# IDE & Editor Files
# ============================================================================
# VSCode
.vscode/
.vscode/*
!.vscode/extensions.json
*.code-workspace
.vscode-test

# WebStorm/IntelliJ
.idea/
*.iml
*.iws
*.ipr
.DS_Store

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim & Neovim
.vim/
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
.\#*

# Atom
.atom/
.atomignore

# VS
.vs/

# ============================================================================
# OS Specific
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
*.swp
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory

# ============================================================================
# Testing & Coverage
# ============================================================================
coverage/
.nyc_output/
*.lcov
*.coverage
.coverage
htmlcov/
.pytest_cache/
__pycache__/
*.py[cod]
*$py.class

# ============================================================================
# CI/CD Temporary Files
# ============================================================================
.sonar/
sonar-scanner-*/
.scannerwork/
.tox/
.cache/
.pytest_cache/

# ============================================================================
# Docker
# ============================================================================
Dockerfile.debug
docker-compose.override.yml
.dockerignore
.docker/

# ============================================================================
# Dependency Cache
# ============================================================================
.cache/
.npm-packages/
.npm-packages-offline-cache/

# ============================================================================
# Logs
# ============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ============================================================================
# OS Generated Files
# ============================================================================
.cfignore
.cfignore.local

# ============================================================================
# IDE Specific
# ============================================================================
.prettierignore
.eslintignore

# ============================================================================
# CI/CD & Build Tools
# ============================================================================
*.jar
*.class
.gradle/
build/
target/

# ============================================================================
# Temporary Files
# ============================================================================
*.tmp
*.temp
*.bak
*.swp
*~
.tmp/

# ============================================================================
# Jenkins Specific
# ============================================================================
.jenkins/
jenkinsfile.local
Jenkinsfile.local

# ============================================================================
# SonarQube Specific
# ============================================================================
.sonar/
.scannerwork/
sonar-project.properties.local

# ============================================================================
# Database Files
# ============================================================================
*.db
*.sqlite
*.sqlite3
*.db3
.mongodb/

# ============================================================================
# Uploads & Temporary Storage
# ============================================================================
uploads/
temp/
tmp/
.tmp/
public/uploads/
static/uploads/

# ============================================================================
# Specific Project Files (if applicable)
# ============================================================================
# For your specific game theory project
game_data/
simulations/
*.backup
*.old

# ============================================================================
# Comments
# ============================================================================
# Note: If you need to commit a file that matches this gitignore,
# use: git add -f <filename>
# or remove the rule from gitignore temporarily

# ============================================================================
# EOF - .gitignore
# ============================================================================
